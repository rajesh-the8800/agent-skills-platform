{
  "name": "agent-skills-platform",
  "private": true,
  "packageManager": "npm@7.7.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run --workspace @agent-skills/api build && npm run --workspace @agent-skills/web build",
    "lint": "npm run --workspace @agent-skills/api lint && npm run --workspace @agent-skills/web lint",
    "format": "prettier -w .",
    "typecheck": "npm run --workspace @agent-skills/api typecheck && npm run --workspace @agent-skills/web typecheck",
    "dev:api": "npm run --workspace @agent-skills/api dev",
    "dev:web": "npm run --workspace @agent-skills/web dev",
    "prisma:generate": "npm run --workspace @agent-skills/api prisma:generate",
    "prisma:migrate": "npm run --workspace @agent-skills/api prisma:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.34.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/multer": "^2.1.0",
    "adm-zip": "^0.5.17"
  }
}
