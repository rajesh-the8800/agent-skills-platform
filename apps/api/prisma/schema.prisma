generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  avatar    String?
  provider  String
  skills    Skill[]  @relation("SkillCreator")
  downloads Download[]
  ratings   Rating[]
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SkillStatus {
  PENDING
  PUBLISHED
  REJECTED
}

model Skill {
  id               String      @id @default(cuid())
  slug             String      @unique
  name             String
  shortDescription String
  description      String
  thumbnailKey     String?
  tags             String[]    @default([])
  supportedAgents  String[]    @default([])
  installCount     Int         @default(0)
  viewCount        Int         @default(0)
  status           SkillStatus @default(PENDING)
  securityScanned  Boolean     @default(false)
  rejectionReason  String?
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  creatorId String
  creator   User   @relation("SkillCreator", fields: [creatorId], references: [id])

  versions    SkillVersion[]
  reviews     Review[]
  ratings     Rating[]
  downloads   Download[]
  categories  SkillCategory[]

  @@index([creatorId])
  @@index([updatedAt])
}

model SkillVersion {
  id         String   @id @default(cuid())
  version    String
  skillMd    String    @db.Text
  files      Json      @db.JsonB
  fileSize   Int
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  skillId String
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, version])
  @@index([skillId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills SkillCategory[]
}

model SkillCategory {
  skillId    String
  categoryId String

  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([skillId, categoryId])
  @@index([categoryId])
}

model Download {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  ipAddress String?

  skillId String
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([skillId])
  @@index([userId])
  @@index([createdAt])
}

model Rating {
  id        String   @id @default(cuid())
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skillId String
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([skillId, userId])
  @@index([skillId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  title     String?
  body      String
  stars     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  skillId String
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([userId])
}

