## Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

## Server-to-server (Web → API). Must match API `INTERNAL_API_SECRET`.
API_URL=http://localhost:3001
INTERNAL_API_SECRET=replace-with-strong-shared-secret

# When no user is signed in, skill publish uses this DB user id (defaults to seed creator `clseed_user_creator`).
# SKILL_SUBMIT_FALLBACK_USER_ID=

## Auth.js (Web)
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-secret
AUTH_GOOGLE_ID=replace-me
AUTH_GOOGLE_SECRET=replace-me
# Public URL of the web app (OAuth callbacks). Local: http://localhost:3000
AUTH_URL=http://localhost:3000

## API
PORT=3001
DATABASE_URL=postgresql://agent_skills:agent_skills_password@localhost:5432/agent_skills?schema=public
API_CORS_ORIGIN=http://localhost:3000
INTERNAL_API_SECRET=replace-with-strong-shared-secret

## AWS (API)
AWS_REGION=us-east-1
AWS_S3_BUCKET=replace-me
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

